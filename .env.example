# ──────────────────────────────────────────────────────────────────────────────
# Sapo MCP — Environment Configuration
# ──────────────────────────────────────────────────────────────────────────────
#
# PRODUCTION vs. TEST STORES
# ──────────────────────────
# `npm run probe` (read-probe) is safe to run against ANY store — GET only.
# `npm run probe:write` (write-probe) is HARD-GUARDED and will REFUSE to run
# unless SAPO_STORE name matches the regex /test|dev|sandbox/i.
#
# Examples of SAFE store names for write-probe:
#   myshop-test, dev-acmecorp, acme-sandbox, teststore
# Examples of BLOCKED store names (production guard kicks in):
#   myshop, acmecorp, livestore, production-shop
#
# ──────────────────────────────────────────────────────────────────────────────

# Required: Sapo store subdomain (e.g. "mystorename" → mystorename.mysapo.net)
# For write-probe: must contain "test", "dev", or "sandbox" (case-insensitive).
SAPO_STORE=mystorename

# Required: Private App credentials from developers.sapo.vn
SAPO_API_KEY=your_api_key_here

# One of the following is required:
SAPO_API_SECRET=your_api_secret_here
# SAPO_API_SECRET_FILE=/run/secrets/sapo_api_secret  # File takes precedence over SAPO_API_SECRET

# Optional: Allowed destructive operation categories (comma-separated or *)
# Values: cancel, delete, delete_strict, inventory_set, shift_close, cashbook_write
# Default: empty (no destructive ops allowed)
SAPO_ALLOW_OPS=

# Optional: Per-tool override (SAPO_ALLOW_TOOL_<UPPERCASE_TOOL_NAME>=1)
# Example: SAPO_ALLOW_TOOL_CANCEL_ORDER=1

# Optional: Pagination cap (default: 10)
SAPO_MAX_AUTO_PAGES=10

# Optional: HTTP retry max attempts (default: 3)
SAPO_RETRY_MAX=3

# Optional: Log level — error, warn, info, debug, trace (default: info)
# WARNING: trace level may log PII. Use only in secure dev environments.
SAPO_LOG_LEVEL=info

# Optional: Opt-in to logging PII at trace level (only "1" or "true" enables it)
# SECURITY WARNING: Never enable in production. Logs may contain customer data.
# SAPO_LOG_PII=1
